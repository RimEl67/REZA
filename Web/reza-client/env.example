# API Configuration
# Backend API URL - The backend server is located in saas/Backend/
# Default port is 5000. Update this if your backend runs on a different port or URL.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional: Google Maps API Key (for map features in search results)
# Get your API key from: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyA6h6NrhseFGkdc0hZZ7BGz0D4IUidbenQ

# Real-time Updates Configuration
# Enable real-time availability updates (default: true)
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true

# Polling interval for availability updates in milliseconds (default: 30000 = 30 seconds)
NEXT_PUBLIC_AVAILABILITY_POLL_INTERVAL=30000

# SaaS Login URL (for pro-info page redirect after registration)
# This is where professionals log in after creating their account
NEXT_PUBLIC_SAAS_LOGIN_URL=http://localhost:3000/login
